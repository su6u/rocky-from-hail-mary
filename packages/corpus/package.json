{
  "name": "@rocky/corpus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && tsc -p tsconfig.test.json && node --test dist/**/*.test.js",
    "sync-corpus": "pnpm build && node scripts/generate-hand-authored.mjs && node scripts/sync-training-corpus.mjs"
  },
  "dependencies": {
    "@rocky/domain": "workspace:*",
    "@rocky/prompt": "workspace:*",
    "@rocky/protocol": "workspace:*",
    "yaml": "2.8.0"
  }
}
